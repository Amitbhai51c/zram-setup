#!/bin/bash

# ==============================
# ZRAM Setup Script (Interactive)
# ==============================

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}==>Made by - [ Amitbhai51 ]${NC}"
sleep 5
echo -e "${BLUE}==> Resetting ZRAM...${NC}"

# Reset everything
sudo swapoff -a
sudo modprobe -r zram 2>/dev/null
sudo modprobe zram num_devices=1

# Confirm device created
if [ ! -e /dev/zram0 ]; then
    echo -e "${RED}Error: /dev/zram0 not found!${NC}"
    exit 1
fi

echo -e "${GREEN}✔ /dev/zram0 created successfully${NC}"

# Ask user for swap size
echo -e "${YELLOW}Enter swap size in GB (example: 4):${NC}"
read -r SIZE_GB

# Validate input
if ! [[ "$SIZE_GB" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Invalid input! Please enter a valid number.${NC}"
    exit 1
fi

# Convert GB → bytes
SIZE_BYTES=$((SIZE_GB * 1024 * 1024 * 1024))

sleep 2

echo -e "${YELLOW}==> Configuring ZRAM (${SIZE_GB}GB, lz4)...${NC}"

# Set compression and size
echo lz4 | sudo tee /sys/block/zram0/comp_algorithm > /dev/null
echo $SIZE_BYTES | sudo tee /sys/block/zram0/disksize > /dev/null

sleep 2

# Format as swap
echo -e "${BLUE}==> Formatting swap...${NC}"
sudo mkswap /dev/zram0

sleep 2

# Activate swap
echo -e "${BLUE}==> Activating swap...${NC}"
sudo swapon /dev/zram0

sleep 2

# Show swap status
echo -e "${GREEN}==> Checking Swap Status${NC}"
echo -e "${GREEN}==> ok !${NC}"
sleep 2
echo -e "${GREEN}✔ ZRAM setup completed successfully!${NC}"
